# ─── Shared Database ───
POSTGRES_USER=hermes
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ─── Google Cloud / Vertex AI (shared by Muse + Honcho) ───
# Place your service account JSON file as gcp-credentials.json in this directory
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=us-central1

# ─── Firebase (shared by progression + sisyphus) ───
FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# ─── Muse ───
DIGEST_CRON=0 7 * * *

# ─── Progression ───
PROGRESSION_CORS_ORIGINS=*
PROGRESSION_AGENT_API_KEY=

# ─── Exodus ───
EXODUS_CORS_ORIGIN=https://your-frontend-domain.com

# ─── Domain (for SSL) ───
DOMAIN=your-domain.com
